rs and 28 MLP layers.\n"]}]},{"cell_type":"code","source":["from google.colab import files\n","from datasets import Dataset\n","import json\n","\n","# 1. Widget pro nahrání souboru\n","print(\"Nahraj svůj JSON soubor (Alpaca style)...\")\n","uploaded = files.upload()\n","filename = next(iter(uploaded))\n","\n","# 2. Načtení dat\n","with open(filename, \"r\", encoding=\"utf-8\") as f:\n","    data = json.load(f)\n","\n","# 3. Formátovací funkce pro Llama 3 Instruct\n","# Alpaca styl má obvykle klíče: \"instruction\", \"input\" (volitelné), \"output\"\n","alpaca_prompt = \"\"\"<|begin_of_text|><|start_header_id|>system<|end_header_id|>\n","\n","Below is an instruction that describes a task, paired with an input that provides further context. Write a response that appropriately completes the request.<|eot_id|><|start_header_id|>user<|end_header_id|>\n","\n","{}\n","\n","{}<|eot_id|><|start_header_id|>assistant<|end_header_id|>\n","\n","{}<|eot_id|>\"\"\"\n","\n","def formatting_prompts_func(examples):\n","    instructions = examples[\"instruction\"]\n","    inputs       = examples[\"input\"]\n","    outputs      = examples[\"output\"]\n","    texts = []\n","    for instruction, input, output in zip(instructions, inputs, outputs):\n","        # Pokud je input prázdný, formátujeme jen instrukci\n","        text = alpaca_prompt.format(instruction, input, output)\n","        texts.append(text)\n","    return { \"text\" : texts, }\n","\n","# Vytvoření HF datasetu\n","dataset = Dataset.from_list(data)\n","dataset = dataset.map(formatting_prompts_func, batched = True)\n","\n","print(f\"Dataset připraven. Příklad formátu:\\n{dataset['text'][0]}\")"],"metadata":{"id":"xLKbSs-HuM5T","colab":{"base_uri":"https://localhost:8080/","height":333,"referenced_widgets":["ea315edb2a144b6883b1632b74440256","718ea694cf324b81a0f4ebc6d0b100be","f3ea4845601b4b1689e582bfc698e9af","c5a856eceaea4c60a1703b9f36ba4199","9d1e0a7ae0f24fcebd8792b2e50c18af","fc6b5eb2b0df45b99645f1fd6df9bd88","96c2e48fd